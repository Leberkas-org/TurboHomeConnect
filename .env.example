# Copy this file to `.env` and fill in your developer-portal values.
# `.env` is in .gitignore — never commit real credentials.

# ── OAuth app credentials ──────────────────────────────────────────────────────
# From https://developer.home-connect.com → My Applications.
# Register this redirect URI on the app: http://localhost:7878/oauth/callback
HOMECONNECT_CLIENT_ID=
HOMECONNECT_CLIENT_SECRET=

# ── Endpoint selection ─────────────────────────────────────────────────────────
# 1 = simulator (simulator.home-connect.com — virtual appliances, recommended for dev)
# 0 = production (api.home-connect.com — real appliances paired to your Bosch account)
HOMECONNECT_USE_SIMULATOR=1

# ── Runtime behavior ───────────────────────────────────────────────────────────
# Set to 1 when running in a container; the OAuth listener will bind to all interfaces
# so the host browser can reach it through Docker's port forward.
HOMECONNECT_BIND_ALL_INTERFACES=1

# Set to 0 for headless / container runs — the URL is always printed regardless.
HOMECONNECT_OPEN_BROWSER=0

# Where to persist OAuth tokens (inside the container — see docker-compose.yml's volume).
HOMECONNECT_TOKEN_FILE=/data/token.json

# How long the sample streams SSE events before exiting.
HOMECONNECT_STREAM_SECONDS=30
